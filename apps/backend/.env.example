# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api
API_VERSION=v1
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://etnof:etnof_secret@localhost:5432/etnof_assistant?schema=public"

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_very_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_very_long_random_string
JWT_REFRESH_EXPIRY=7d

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.2

# Active AI provider: openai | google
AI_PROVIDER=openai

# Logging
LOG_LEVEL=debug
